# Copy to .env (under apps/api/) or root. NEVER commit.

DATABASE_URL=postgresql://gw2analytics:gw2analytics@localhost:5432/gw2analytics
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=gw2analytics
S3_SECRET_KEY=gw2analytics-secret
S3_BUCKET=gw2analytics
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ENV=dev

# v0.9.1 webhook SSRF defense (plan 005). When unset (default) the
# webhook URL validator blocks any resolved address that targets a
# private/loopback/link-local/multicast range (covers IPv4 RFC1918 +
# 127.0.0.0/8 + 169.254/16 + IPv6 ::1 + fc00::/7 + fe80::/10).
PRODUCTION DEPLOYMENTS MUST KEEP THIS UNSET (= strict).
Set to 1 ONLY in trusted dev environments where the webhook
# subscriber needs to reach an internal endpoint (e.g. a local Redis
# or service-mesh proxy). DO NOT set in production -- a leaked env
# turns the gateway into an SSRF vector against internal services
# (AWS IMDS, internal admin panels, etc.).
# GW2ANALYTICS_ALLOW_PRIVATE_WEBHOOK_URLS=

# v0.10.0 plan 031: webhook secret at rest envelope encryption (Fernet).
# REQUIRED at app startup; the gateway refuses to boot without a
# KEK of exactly 44 chars (URL-safe base64 of 32 random bytes = the
# Fernet key format). Generate via:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Store in a secrets manager (Vault / AWS Secrets Manager / sealed-secrets).
# NEVER commit the real KEK to git.
#
# WARNING: data loss risk. SECRETS_KEK is the SOLE decryption key.
# If it is lost or rotated without running a future KEK-rotation
# migration (planned for v0.10.0+), ALL existing webhook subscriptions
# will PERMANENTLY fail to dispatch. HMAC signatures will be silently
# wrong on every POST (cryptography.fernet.InvalidToken caught + logged
# but never recovered). Operators MUST:
# 1. Store the KEK in a secrets manager. NEVER commit.
# 2. Test KEK recovery by decrypting a known ciphertext row before
#    relying on the encryption layer in production.
# 3. Plan future KEK rotations through a v0.10.0+-era migration that
#    re-encrypts every ciphertext row in place.
SECRETS_KEK=

# v0.10.1 plan 010: Arq parser worker (replaces BackgroundTasks).
# The Arq broker is the Redis instance declared in docker-compose.yml.
# Both the FastAPI app's lifespan (initialises the enqueue pool) and
# the Arq worker process (dequeues ``parse_job``) read these at
# import time. Defaults (``localhost`` + 6379) match the local
# ``docker compose up -d redis`` dev setup; override here for a
# remote broker in staging/production.
# ARQ_REDIS_HOST=localhost
# ARQ_REDIS_PORT=6379

# v0.10.1 plan 010: in-request parse fallback (escape hatch for
# production safety + test env). When UNSET (default, production
# recommended), a misconfigured Arq broker surfaces as ``503 Service
# Unavailable`` on POST /api/v1/uploads (the operator sees the
# misconfiguration via HTTP 5xx in their dashboard + WARNING logs).
# When SET to ``1``, the route handler falls back to running the
# parse + dispatch in-request via ``asyncio.to_thread`` (graceful
# degradation: the API still serves traffic, but uploads become
# GIL-bound and slow at high concurrency -- bug #2 mitigation is
# NOT active in this path). Test env sets this to ``1`` via the
# ``_disable_arq_for_tests`` conftest fixture.
# ALLOW_INREQUEST_PARSE_FALLBACK=
