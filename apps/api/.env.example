# Copy to .env (under apps/api/) or root. NEVER commit.

DATABASE_URL=postgresql://gw2analytics:gw2analytics@localhost:5432/gw2analytics
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=gw2analytics
S3_SECRET_KEY=gw2analytics-secret
S3_BUCKET=gw2analytics
SECRET_KEY=change-me-to-a-random-32-byte-hex-string
ENV=dev

# v0.9.1 webhook SSRF defense (plan 005). When unset (default) the
# webhook URL validator blocks any resolved address that targets a
# private/loopback/link-local/multicast range (covers IPv4 RFC1918 +
# 127.0.0.0/8 + 169.254/16 + IPv6 ::1 + fc00::/7 + fe80::/10).
PRODUCTION DEPLOYMENTS MUST KEEP THIS UNSET (= strict).
Set to 1 ONLY in trusted dev environments where the webhook
# subscriber needs to reach an internal endpoint (e.g. a local Redis
# or service-mesh proxy). DO NOT set in production -- a leaked env
# turns the gateway into an SSRF vector against internal services
# (AWS IMDS, internal admin panels, etc.).
# GW2ANALYTICS_ALLOW_PRIVATE_WEBHOOK_URLS=

