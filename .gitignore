# Codegen artifacts (web/scripts/dump_openapi.py output)
/openapi.json

# Playwright (v0.7.2) test artifacts
# - test-results/ holds the per-test trace + screenshot
#   bundles (retained on failure via
#   ``trace: "retain-on-failure"`` in web/playwright.config.ts).
# - playwright-report/ holds the HTML report (generated in
#   CI via ``reporter: "html"`` for the artifact upload; the
#   local loop uses the ``list`` reporter so this stays empty
#   unless someone runs ``pnpm exec playwright test
#   --reporter=html``).
web/test-results/
web/playwright-report/

# Marketing-grade screenshots (web/scripts/screenshots.mjs output)
# - ``/screenshots/`` is the absolute OUT_DIR the script writes
#   to from the repo root (matches the convention of
#   ``web/scripts/dump_openapi.py`` -> ``/openapi.json``).
# - ``web/screenshots/`` is the legacy write target from an
#   earlier draft of the script that hardcoded a relative
#   path. The current script does not touch it; the directory
#   is gitignored so it stops showing up in ``git status`` but
#   is preserved on disk for the developer to inspect or remove
#   manually with ``rm -rf web/screenshots/`` if desired.
# The script itself (web/scripts/screenshots.mjs) IS tracked --
# it's the source-of-truth artifact; only the binary output is
# ignored (consistent with how the openapi.json codegen
# artifact is treated just above).
/screenshots/
web/screenshots/
