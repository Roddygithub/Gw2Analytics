# OS
Thumbs.db

# Codegen artifacts (web/scripts/dump_openapi.py output)
/openapi.json

# Playwright (v0.7.2) test artifacts
# - test-results/ holds the per-test trace + screenshot
#   bundles (retained on failure via
#   ``trace: "retain-on-failure"`` in web/playwright.config.ts).
# - playwright-report/ holds the HTML report (generated in
#   CI via ``reporter: "html"`` for the artifact upload; the
#   local loop uses the ``list`` reporter so this stays empty
#   unless someone runs ``pnpm exec playwright test
#   --reporter=html``).
web/test-results/
web/playwright-report/

# Visual-baseline diff artifacts (web/tests/e2e/visual-regression.spec.ts output).
# Generated on failure (the spec's dimension-mismatch + diff step
# drops a ``*-actual.png`` + ``*-diff.png`` pair into this dir for
# analyst inspection); never commit. The committed PNGs in
# ``docs/screenshots/`` are the canonical baselines; the
# ``web/scripts/screenshots.mjs`` sibling regenerates them on
# ``pnpm screenshots --persist``.
web/tests/e2e/.visual-regression-output/

# Marketing screenshots (web/scripts/screenshots.mjs output).
# The script is tracked; only the PNGs are ignored
# (mirrors the dump_openapi.py -> /openapi.json convention above).
/screenshots/
web/screenshots/

# Per-release operator-facing transfer artefacts (placed at the
# project root for the analyst's local-session use during each
# release window; never committed). Force-add a specific file via
# ``git add -f <file>`` if a future maintainer wants to keep one
# as a project asset:
#   - PUSH_INSTRUCTIONS*.md: 1-shot manual ``gh pr create``
#     recipe (per-release; one-time use during each wave's
#     release window).
#   - handoff*.md: per-release v0.10.x night-mode status doc
#     (operator-facing handoff; each release window may have its
#     own numbered handoff).
#   - v*-pre.bundle: per-release git bundle for offline
#     transfer (binary; never committed -- git bundles are
#     first-class transfer artefacts, not project assets). The
#     ``-pre`` suffix matches the canonical v0.10.x
#     pre-release naming convention (vMAJOR.MINOR.PATCH-pre).
/PUSH_INSTRUCTIONS*.md
/handoff*.md
/v*-pre.bundle
.aider*
