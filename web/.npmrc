# pnpm 11 deprecated `pnpm.onlyBuiltDependencies` in package.json.
# CI runners + fresh dev clones run with empty user-level
# ``~/.npmrc``, so ``pnpm approve-builds --all`` cannot pre-approve
# deps on a runner's behalf. Allow all build scripts at the
# install gate so ``pnpm install --frozen-lockfile`` returns 0
# even on a fresh container. This IS the single source of truth
# for the build-script allowlist; the previous per-dep list (sharp
# + esbuild via ``onlyBuiltDependencies[]``) is now ornamental
# and intentionally dropped.
dangerouslyAllowAllBuilds=true
