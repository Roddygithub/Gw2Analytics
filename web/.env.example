[TEMPLATE]
# ---------------------------------------------------------------------------
# API_BASE_URL (v0.9.9 plan 033 + v0.10.4)
# ---------------------------------------------------------------------------
# The full URL of the FastAPI gateway. Used by Server Components via
# `apiBaseUrl` from `@/lib/env`.
#
# In dev: optional -- defaults to http://localhost:8000 so the dev loop
# works without any env var setup. `docker compose up -d` then
# `uv run fastapi dev apps/api/src/gw2analytics_api/main.py` matches
# the default.
#
# In production (NODE_ENV=production): REQUIRED -- the app fails fast
# at boot if unset or invalid (validated via the native `new URL()`
# constructor). The validation rejects relative paths, non-URL strings,
# typos like missing scheme, hostname typos, etc. Trailing slashes are
# stripped automatically (`http://x/api/` -> `http://x/api`). Leading
# and trailing whitespace is trimmed automatically.
#
# Example (replace with your real hostname in production):
#   API_BASE_URL=https://api.gw2analytics.example.com
# ---------------------------------------------------------------------------
API_BASE_URL=http://localhost:8000

# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL (v0.9.9 plan 033 + v0.10.4, optional)
# ---------------------------------------------------------------------------
# The same URL as API_BASE_URL, but exposed to Client Components via
# Next.js's `NEXT_PUBLIC_*` inlining (available at the client at
# RUNTIME, not just at build time for static optimisation). A future
# Client Component that needs the URL should import `clientApiBaseUrl`
# from `@/lib/env` instead of `apiBaseUrl` (the server-side export).
#
# In dev: defaults to API_BASE_URL at runtime if unset, so the dev loop
# works without any env var setup.
#
# In production (NODE_ENV=production): recommended to set this
# EXPLICITLY to the production URL (so the client and server agree).
# If unset, falls back to API_BASE_URL at runtime client-side fetch
# time -- the SAME validation rules apply (new URL() + trim + strip).
#
# Example (uncomment and replace with your real hostname in production):
#   NEXT_PUBLIC_API_BASE_URL=https://api.gw2analytics.example.com
# ---------------------------------------------------------------------------
# NEXT_PUBLIC_API_BASE_URL=https://api.gw2analytics.example.com
