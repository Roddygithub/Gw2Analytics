{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm generate:api && next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test --project=chromium",
    "test:e2e:headed": "playwright test --headed",
    "screenshots": "node scripts/screenshots.mjs",
    "generate:api": "uv run python scripts/dump_openapi.py > openapi.json && pnpm exec openapi-typescript openapi.json -o ./src/lib/api/schema.d.ts && rm openapi.json",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest-axe": "^3.5.9",
    "@types/node": "^20.19",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^3.2.7",
    "ag-grid-community": "^34",
    "ag-grid-react": "^34",
    "axe-core": "^4.12.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "jest-axe": "^10.0.0",
    "jsdom": "^25",
    "openapi-typescript": "^7.13.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6"
  }
}
