# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Generated OpenAPI spec (re-derived from `app.openapi()` on every
# codegen run; never commit). Use `pnpm generate:api` to refresh.
openapi.json

# Committed `src/lib/api/schema.d.ts` is the OpenAPI drift-gate
# baseline (v0.9.1 plan 008). Regenerate via `pnpm generate:api`
# whenever a `apps/api/src/gw2analytics_api/routes/*` file changes
# shape (new endpoint, renamed parameter, changed response shape)
# and commit the regenerated schema.d.ts in the SAME PR -- the CI
# `Detect API client drift` step fails the build otherwise.
